# ----------------------------------------------------------------------------
# China Sky — User Site environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values for your environment.
# Variables MUST be prefixed with `VITE_` to be exposed to the client bundle.
# ----------------------------------------------------------------------------

# Absolute backend root. If set, the API client uses this directly and the dev
# proxy is bypassed. Use this for staging/production builds.
# Example: https://api.chinasky.com/api
VITE_API_BASE_URL=

# Dev-only: where Vite should forward "/api" requests during `npm run dev`.
# Used only when VITE_API_BASE_URL is empty.
VITE_API_PROXY_TARGET=http://localhost:4000

# localStorage key under which the auth token is persisted.
VITE_AUTH_TOKEN_KEY=chinasky_user_token

# Per-request timeout in milliseconds.
VITE_API_TIMEOUT_MS=30000
